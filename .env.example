# --- Server ---
PORT=3030

# --- Postgres (для Drizzle ORM, Спринт 2) ---
# Получите URL после bash deploy/install-postgres.sh
DATABASE_URL=
# Включить логи SQL-запросов Drizzle (для дебага)
PG_LOG=false
NODE_ENV=production
APP_BASE_URL=https://staging.marketradar24.ru/call-agent

# --- Auth (MVP, один админ) ---
ADMIN_LOGIN=admin
# bcrypt-хеш пароля: node -e "console.log(require('bcryptjs').hashSync('пароль', 10))"
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# --- Bitrix24 ---
# Классический входящий webhook:  https://<portal>.bitrix24.ru/rest/<userId>/<token>/
BITRIX_WEBHOOK_URL=
# Секрет для проверки исходящих вебхуков (исходящий вебхук Bitrix или ваш собственный)
BITRIX_INBOUND_TOKEN=
# Безопасный режим: транскрипция и анализ работают,
# но обратная запись в карточку CRM НЕ выполняется.
# Установите =true при первом запуске чтобы проверить пайплайн без касания Битрикса.
BITRIX_DRY_RUN=true

# --- AI ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
# Прокси для OpenAI (нужен для РФ — обход гео-блока 403)
# См. deploy/openai-cf-worker.js — готовый код для Cloudflare Worker
# Пример: https://openai-proxy.your-name.workers.dev/v1
OPENAI_BASE_URL=

# --- Storage ---
RECORDINGS_DIR=./storage/recordings
RECORDINGS_TTL_DAYS=30

# --- Cross-product admin (MarketRadar → Call-Agent) ---
# Shared secret для server-to-server вызовов из админ-панели MarketRadar.
# Используется в /api/admin/users и /api/admin/refs.
# Должен совпадать со значением CA_ADMIN_TOKEN в .env MarketRadar.
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CA_ADMIN_TOKEN=
